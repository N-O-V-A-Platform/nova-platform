# Project Settings
PROJECT_NAME=nova-backend
VERSION=1.0.0
DEBUG=True

# Secret key for JWT signature
SECRET_KEY=change-this-to-a-secure-random-value-in-production

# Database Connection
# format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://nova_user:nova_password@db:5432/nova_db

# Redis Connection
REDIS_URL=redis://redis:6379/1
