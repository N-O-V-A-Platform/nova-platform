# Application Settings
APP_NAME=N.O.V.A API
APP_VERSION=1.0.0
DEBUG=True
API_V1_STR=/api/v1

# Security
# Run "openssl rand -hex 32" to generate a secure key
JWT_SECRET_KEY=change-this-to-a-secure-random-value-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Connections
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://nova_user:nova_password@db:5432/nova_db
REDIS_URL=redis://redis:6379/0

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External AI Provider Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
PINECONE_API_KEY=
